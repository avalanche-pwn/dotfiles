let g:vim_session_dir='~/.vim/sessions/'

function! GetSessionName()
    let l:cwd = getcwd()
    return substitute(l:cwd, '/', '_', 'g') . '.vim'
endfunction

function! SaveSession()
    execute 'mksession! ' . g:vim_session_dir . GetSessionName()
endfunction

function! ShouldLoadSession()
    return len(v:argv) <= 1 || empty(glob(v:argv[1]))
endfunction

function! LoadSession()
    if !ShouldLoadSession()
        return
    endif

    let l:session_path = g:vim_session_dir . GetSessionName()
    if empty(glob(l:session_path))
        return
    endif

    let l:choice = confirm('There exists a session for ' . getcwd() . '. Do you want to load it?', "&Yes\n&No", 2)
    if choice == 1
        execute 'source ' . l:session_path
    endif
endfunction

autocmd VimLeave * call SaveSession()
autocmd VimEnter * call LoadSession()

