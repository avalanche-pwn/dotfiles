" Setting up correct runcmd for some files
let g:gruncmd = "echo 'If you wish to be able to run using this shortcut set g:gruncmd or b:runcmd.'"
let b:runcmd = g:gruncmd
function! Run()
    if g:gruncmd == "echo 'If you wish to be able to run using this shortcut set g:gruncmd or b:runcmd.'" || g:gruncmd == ""
        call system('tmux display-popup -E "(cd '.getcwd().' && '.b:runcmd.') && read -n1 kbd"')
    else
        call system('tmux display-popup -E "(cd '.getcwd().' && '.g:gruncmd.') && read -n1 kbd"')
    endif
endfunction

