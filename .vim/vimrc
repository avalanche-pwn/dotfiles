function! FZF_all()
    let file = system('find . -type f |fzf --tmux top,50%,20% ')
    :execute 'edit' file
endfunction

function! FZF() 
    if system('git rev-parse --is-inside-work-tree 2>/dev/null') =~# 'true'
        let file = system('git ls-files | fzf --tmux top,50%,20%')
    else
        let file = system('find . -type f |fzf --tmux top,50%,20%')
    endif
    :execute 'edit' file
endfunction
